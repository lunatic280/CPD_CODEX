# 기본적으로 텍스트 파일은 LF 기준으로 저장
* text=auto eol=lf

# Windows 실행/스크립트 파일은 CRLF 허용
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# 이미지/바이너리 파일은 줄바꿈 변환 금지
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.keystore binary

# Flutter/Dart 관련
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf
*.gradle text eol=lf
*.kts text eol=lf